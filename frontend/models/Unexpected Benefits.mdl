{UTF-8}
Adults= INTEG (
	Ageing1-Ageing2,
		Init Value A)
	~	
	~		|

Ageing=
	Kids/AgeingKids
	~	people/year
	~		|

Ageing1=
	Youngsters/AgeingYoungsters
	~	people/year
	~		|

Ageing2=
	Adults/AgeingAdults
	~	people/year
	~		|

AgeingAdults=
	40
	~	year
	~		|

AgeingKids=
	12
	~	year
	~		|

AgeingYoungsters=
	12
	~	year
	~		|

criminalY=
	50
	~	
	~		|

birth=
	Adults*rateOfBirthA*birthcontrol+rateOfBirthY*Youngsters*birthcontrol
	~	
	~		|

birthcontrol=
	0.25
	~	
	~		|

Crime flow=
	crimerateK+crimerateA+crimerateR+CrimesByOthers+crimerateY
	~	
	~		|

crimeperyear=
	crimerateK+crimerateA+crimerateR+crimerateY+CrimesByOthers
	~	
	~		|

crimerateA=
	Adults*criminalactsApY*criminalKY
	~	
	~		|

crimerateK=
	Kids*criminalK*criminalactsKpY
	~	
	~		|

crimerateR=
	criminalactsRpY*criminalR*Retirees
	~	
	~		|

crimerateY=
	criminalactsYpY*criminalY*Youngsters
	~	
	~		|

Crimes= INTEG (
	Crime flow,
		0)
	~	
	~		|

CrimesByOthers=
	6e+06
	~	
	~		|

criminalactsApY=
	12
	~	
	~		|

criminalactsKpY=
	2
	~	
	~		|

criminalactsRpY=
	4
	~	
	~		|

criminalactsYpY=
	4
	~	
	~		|

criminalK=
	5
	~	
	~		|

criminalKY=
	60
	~	
	~		|

criminalR=
	10
	~	
	~		|

Retirees= INTEG (
	Ageing2-Retiree Deaths,
		Init Value R)
	~	
	~		|

totalpopulation=
	Adults+Kids+Retirees+Youngsters
	~	
	~		|

Youngsters= INTEG (
	Ageing-Ageing1,
		Init Value Y)
	~	
	~		|

rateOfBirthY=
	0.003
	~	
	~		|

rateOfBirthA=
	0.03
	~	
	~		|

Kids= INTEG (
	birth-Ageing,
		Init Value)
	~	
	~		|

average time Retiree=
	15
	~	year
	~		|

Init Value=
	1e+06
	~	people
	~		|

Init Value A=
	3e+06
	~	people
	~		|

Init Value R=
	75000
	~	people
	~		|

Init Value Y=
	1e+06
	~	people
	~		|

Retiree Deaths=
	Retirees/average time Retiree
	~	people/year
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 50
	~	Month
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Month
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Month [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.25
	~	Month [0,?]
	~	The time step for the simulation.
	|

