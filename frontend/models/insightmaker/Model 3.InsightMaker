        </mxGeometry>
      </mxCell>
    </Flow>
    <Variable name="Max vaccination rate" Note="This only indicates what is the absolute max # of people we can vaccinate per day. Ensuring that we have enough vaccine doses and syringes, swabs and people to perform vaccinations.​" Equation="8738" Units="Unitless" MaxConstraintUsed="false" MinConstraintUsed="false" MaxConstraint="100" MinConstraint="0" ShowSlider="true" SliderMax="100000" SliderMin="0" SliderStep="" Image="None" FlipHorizontal="false" FlipVertical="false" LabelPosition="Middle" id="47">
