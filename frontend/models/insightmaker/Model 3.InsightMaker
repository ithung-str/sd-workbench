    <Flow name="Becoming Immune" Note="We vaccinate people either to the Maximum Capacity that is constrained by # of vaccines and locations &amp;amp; people to perform vaccinations or the amount of people still susceptible​" FlowRate="Min([Vaccination Rate] * [Susceptible], [Max vaccination rate]*[Vaccination capacity growth]) " OnlyPositive="true" TimeIndependent="false" Units="Unitless" MaxConstraintUsed="false" MinConstraintUsed="false" MaxConstraint="100" MinConstraint="0" ShowSlider="false" SliderMax="100" SliderMin="0" SliderStep="" id="46">
