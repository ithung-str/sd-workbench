    <Variable name="Vaccination Rate" Note="% percent of the population that we vaccinate per day​" Equation="0.03" Units="Unitless" MaxConstraintUsed="false" MinConstraintUsed="false" MaxConstraint="100" MinConstraint="0" ShowSlider="false" SliderMax="100" SliderMin="0" SliderStep="" Image="None" FlipHorizontal="false" FlipVertical="false" LabelPosition="Middle" id="44">
      <mxCell style="variable" parent="1" vertex="1">
