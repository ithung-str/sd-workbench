{UTF-8}
Housing construction=
	 HCN*Housing land multiplier*Housing availability multiplier*Housing
	~ structure/year ~ |

Net births=
	 (BN-DN)*Population
	~ people/year ~ |

Business construction=
	BCN*Business land multiplier*Business labor force multiplier*Business structures
	~ structure/year ~ |

Outmigration=
	Population*OMN
	~ people/year ~ |

Inmigration=
	Population*IMN*Attractiveness from jobs multiplier*Attractvieness from housing multiplier
	~ people/year ~ |

Population= INTEG (
	Net births+Inmigration-Outmigration,
		50000)
	~ people ~ |

Area = 10000
	~ acres ~ |

Attractiveness from jobs multiplier= WITH LOOKUP (
	Labor to job ratio,
		([(0,0)-(2,2)],(0,2),(0.2,1.95),(0.4,1.8),(0.6,1.6),(0.8,1.35)
		,(1,1),(1.2,0.5),(1.4,0.3),(1.6,0.2),(1.8,0.15),(2,0.1)))
	~ fraction ~ |

Attractvieness from housing multiplier= WITH LOOKUP (
	Households to housing ratio,
		([(0,0)-(2,2)],(0,1.4),(0.2,1.4),(0.4,1.35),(0.6,1.3),(0.8,1.15)
		,(1,1),(1.2,0.8),(1.4,0.65),(1.6,0.5),(1.8,0.45),(2,0.4)))
	~ fraction ~ |

BCN = 0.07
	~ fraction/year ~ |

BDN = 0.025
	~ fraction/year ~ |

BN = 0.03
	~ fraction/year ~ |

Business demolition = BDN*Business structures
	~ structure/year ~ |

Business labor force multiplier= WITH LOOKUP (
	Labor to job ratio,
		([(0,0)-(2,2)],(0,0.2),(0.2,0.25),(0.4,0.35),(0.6,0.5),
		(0.8,0.7),(1,1),(1.2,1.35),(1.4,1.6),(1.6,1.8),(1.8,1.95),(2,2)))
	~ fraction ~ |

Business land multiplier= WITH LOOKUP (
	Land fraction occupied,
		([(0,0)-(1,2)],(0,1),(0.1,1.15),(0.2,1.3),(0.3,1.4),(0.4,1.45)
		,(0.5,1.4),(0.6,1.3),(0.7,0.9),(0.8,0.5),(0.9,0.25),(1,0)))
	~ fraction ~ |

Business structures = INTEG(Business construction-Business demolition,1000)
	~ structure ~ |

DN = 0.015
	~ fraction/year ~ |

HCN = 0.07
	~ fraction/year ~ |

HDN = 0.015
	~ fraction/year ~ |

Households to housing ratio = (Population/HS)/Housing
	~ family/structure ~ |

Housing = INTEG(Housing construction-Housing demolition,14000)
	~ structure ~ |

Housing availability multiplier= WITH LOOKUP (
	Households to housing ratio,
		([(0,0)-(2,2)],(0,0.2),(0.2,0.25),(0.4,0.35),(0.6,0.5),(0.8,0.7)
		,(1,1),(1.2,1.35),(1.4,1.6),(1.6,1.8),(1.8,1.95),(2,2)))
	~ fraction ~ |

Housing demolition = HDN*Housing
	~ structure/year ~ |

Housing land multiplier= WITH LOOKUP (
	Land fraction occupied,
		([(0,0)-(1,2)],(0,0.4),(0.1,0.7),(0.2,1),(0.3,1.25),(0.4,1.45)
		,(0.5,1.5),(0.6,1.5),(0.7,1.4),(0.8,1),(0.9,0.5),(1,0)))
	~ fraction ~ |

HS = 4
	~ people/family ~ |

IMN = 0.1
	~ fraction/year ~ |

Jobs = JPBS*Business structures
	~ job ~ |

JPBS = 18
	~ job/structure ~ |

Labor force = LPF*Population
	~ people ~ |

Labor to job ratio = Labor force/Jobs
	~ people/job ~ |

Land fraction occupied = (Business structures*LPBS + Housing*LPH)/Area
	~ fraction ~ |

LPBS = 0.2
	~ acres/structure ~ |

LPF = 0.35
	~ fraction ~ |

LPH = 0.1
	~ acres/structure ~ |

OMN = 0.07
	~ fraction/year ~ |

********************************************************
	.Control
********************************************************~
		Simulation Control Paramaters
	|

FINAL TIME  = 100
	~ year
	~ The final time for the simulation. |

INITIAL TIME  = 0
	~ year
	~ The initial time for the simulation. |

SAVEPER  = 
        TIME STEP 
	~ year
	~ The frequency with which output is stored. |

TIME STEP  = 0.125
	~ year
	~ The time step for the simulation. |

