{UTF-8}
initial value=
	300
	~	cars
	~		|

initial value2=
	300
	~	cars
	~		|

initial value23=
	300
	~	cars
	~		|

initial value3=
	300
	~	cars
	~		|

Inventory= INTEG (
	production-sales,
		initial value)
	~	cars
	~		|

inventory correction=
	(target inventory-Inventory)/time to correct inventory
	~	cars/Month
	~		|

inventory correction2=
	(target inventory2-Inventory2)/time to correct inventory2
	~	cars/Month
	~		|

inventory correction23=
	(target inventory23-Inventory23)/time to correct inventory23
	~	cars/Month
	~		|

inventory correction3=
	(target inventory3-Inventory3)/time to correct inventory3
	~	cars/Month
	~		|

inventory coverage=
	3
	~	Month
	~		|

inventory coverage2=
	3
	~	Month
	~		|

inventory coverage23=
	3
	~	Month
	~		|

inventory coverage3=
	3
	~	Month
	~		|

Inventory2= INTEG (
	production2-sales2,
		initial value2)
	~	cars
	~		|

Inventory23= INTEG (
	production23-sales23,
		initial value23)
	~	cars
	~		|

Inventory3= INTEG (
	production3-sales3,
		initial value3)
	~	
	~		|

net hire=
	(target workforce-workforce)/time to adjust workforce
	~	
	~		|

net hire2=
	(target workforce2-workforce2)/time to adjust workforce2
	~	
	~		|

net hire23=
	(target workforce23-workforce23)/time to adjust workforce23
	~	
	~		|

net hire3=
	(target workforce3-workforce3)/time to adjust workforce3
	~	
	~		|

net hiring=
	(target workforce-workforce)/time to adjust workforce
	~	
	~		|

net hiring2=
	(target workforce2-workforce2)/time to adjust workforce2
	~	
	~		|

net hiring23=
	(target workforce23-workforce23)/time to adjust workforce23
	~	
	~		|

net hiring3=
	(target workforce3-workforce3)/time to adjust workforce3
	~	
	~		|

production=
	productivity*workforce
	~	
	~		|

production2=
	productivity2*workforce2
	~	
	~		|

production23=
	productivity23*workforce23
	~	
	~		|

production3=
	productivity3*workforce3
	~	
	~		|

productivity=
	1
	~	
	~		|

productivity2=
	1
	~	
	~		|

productivity23=
	1
	~	
	~		|

productivity3=
	1
	~	
	~		|

sales=
	sales23
	~	cars/Month
	~		|

sales2=
	sales23
	~	cars/Month
	~		|

sales23=
	100+STEP(50,20)+STEP(-50,35)
	~	cars/Month
	~		|

sales3=
	100+STEP(50,20)
	~	cars/Month
	~		|

target inventory=
	inventory coverage*sales
	~	cars
	~		|

target inventory2=
	inventory coverage2*sales2
	~	cars
	~		|

target inventory23=
	inventory coverage23*sales23
	~	cars
	~		|

target inventory3=
	inventory coverage3*sales3
	~	cars
	~		|

target production=
	inventory correction+sales
	~	cars/Month
	~		|

target production2=
	inventory correction2+sales2
	~	cars/Month
	~		|

target production23=
	inventory correction23+sales23
	~	cars/Month
	~		|

target production3=
	inventory correction3+sales3
	~	cars/Month
	~		|

target workforce=
	target production/productivity
	~	
	~		|

target workforce2=
	target production2/productivity2
	~	
	~		|

target workforce23=
	target production23/productivity23
	~	
	~		|

target workforce3=
	target production3/productivity3
	~	
	~		|

time to adjust workforce=
	10
	~	
	~		|

time to adjust workforce2=
	10
	~	
	~		|

time to adjust workforce23=
	5
	~	
	~		|

time to adjust workforce3=
	10
	~	
	~		|

time to correct inventory=
	2
	~	Month
	~		|

time to correct inventory2=
	2
	~	Month
	~		|

time to correct inventory23=
	1
	~	Month
	~		|

time to correct inventory3=
	2
	~	Month
	~		|

workforce= INTEG (
	net hiring,
		target workforce)
	~	
	~		|

workforce2= INTEG (
	net hiring2,
		target workforce2)
	~	
	~		|

workforce23= INTEG (
	net hiring23,
		target workforce23)
	~	
	~		|

workforce3= INTEG (
	net hiring3,
		target workforce3)
	~	
	~		|

